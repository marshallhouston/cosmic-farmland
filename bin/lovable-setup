#!/usr/bin/env bash
set -euo pipefail

# lovable-setup: Standardize a Lovable project for Railway deployment + Claude Code
#
# Usage: lovable-setup [project-dir]
#   project-dir: path to the Lovable project (default: current directory)
#
# What it does:
#   1. Cleans up lockfiles — ensures Bun only (removes npm/yarn/pnpm artifacts)
#   2. Adds production start script (bunx serve)
#   3. Upgrades all dependencies to latest
#   4. Sets up .gitignore and .railwayignore
#   5. Creates CLAUDE.md scaffold
#   6. Builds to verify everything works
#   7. Commits all setup changes
#   8. Optionally creates Railway project + domain

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

info()  { echo -e "${BLUE}▸${NC} $1"; }
ok()    { echo -e "${GREEN}✓${NC} $1"; }
warn()  { echo -e "${YELLOW}⚠${NC} $1"; }
fail()  { echo -e "${RED}✗${NC} $1"; exit 1; }

PROJECT_DIR="${1:-.}"
PROJECT_DIR="$(cd "$PROJECT_DIR" && pwd)"
PROJECT_NAME="$(basename "$PROJECT_DIR")"

cd "$PROJECT_DIR"

echo ""
echo -e "${BLUE}━━━ lovable-setup: $PROJECT_NAME ━━━${NC}"
echo ""

# ── Preflight checks ──────────────────────────────────────────────────
command -v bun >/dev/null 2>&1 || fail "bun not found. Install with: brew install oven-sh/bun/bun"
command -v git >/dev/null 2>&1 || fail "git not found"
[ -f package.json ] || fail "No package.json found in $PROJECT_DIR"
git rev-parse --is-inside-work-tree >/dev/null 2>&1 || fail "Not a git repository"

# ── 1. Clean up lockfiles — Bun only ─────────────────────────────────
info "Cleaning up lockfiles (Bun only)..."
rm -f package-lock.json yarn.lock pnpm-lock.yaml
ok "Removed non-Bun lockfiles"

# ── 2. Add/fix production start script ────────────────────────────────
info "Checking start script..."
if ! grep -q '"start"' package.json; then
  # Insert start script after the preview line, or after build line
  if grep -q '"preview"' package.json; then
    sed -i '' '/"preview"/a\
    "start": "bunx serve dist -s -l ${PORT:-3000}",
' package.json
  else
    sed -i '' '/"build"/a\
    "start": "bunx serve dist -s -l ${PORT:-3000}",
' package.json
  fi
  ok "Added start script"
else
  # Ensure it uses bunx
  if grep -q '"start":.*serve' package.json && ! grep -q 'bunx serve' package.json; then
    sed -i '' 's|"start":.*serve|"start": "bunx serve|' package.json
    ok "Updated start script to use bunx"
  else
    ok "Start script already configured"
  fi
fi

# ── 3. Upgrade dependencies ──────────────────────────────────────────
info "Upgrading all dependencies to latest..."
bun update --latest 2>&1 | tail -5
ok "Dependencies upgraded"

# ── 4. Install dependencies ──────────────────────────────────────────
info "Installing dependencies..."
rm -rf node_modules
bun install 2>&1 | tail -3
ok "Dependencies installed"

# ── 5. .gitignore ────────────────────────────────────────────────────
info "Updating .gitignore..."
GITIGNORE_ENTRIES=(".claude" "package-lock.json" "yarn.lock" "pnpm-lock.yaml")
for entry in "${GITIGNORE_ENTRIES[@]}"; do
  if ! grep -qxF "$entry" .gitignore 2>/dev/null; then
    echo "$entry" >> .gitignore
  fi
done
ok ".gitignore updated"

# ── 6. .railwayignore ───────────────────────────────────────────────
info "Setting up .railwayignore..."
cat > .railwayignore << 'IGNORE'
.claude
.git
node_modules
IGNORE
ok ".railwayignore created"

# ── 7. CLAUDE.md ─────────────────────────────────────────────────────
if [ ! -f CLAUDE.md ]; then
  info "Creating CLAUDE.md..."
  cat > CLAUDE.md << CLAUDEMD
# $PROJECT_NAME

## Stack

- **Framework:** React + TypeScript (Vite)
- **Styling:** Tailwind CSS + shadcn/ui
- **Package manager:** Bun
- **Deployment:** Railway (auto-deploy from GitHub)
- **Origin:** Lovable scaffold

## Commands

- \`bun install\` — install dependencies
- \`bun run dev\` — start dev server
- \`bun run build\` — production build
- \`bun run test\` — run tests
- \`bun run start\` — serve production build (used by Railway)

## Project Structure

- \`src/\` — application source
- \`src/components/\` — React components (shadcn/ui based)
- \`src/pages/\` — route pages
- \`public/\` — static assets
CLAUDEMD
  ok "CLAUDE.md created"
else
  ok "CLAUDE.md already exists"
fi

# ── 8. Build verification ────────────────────────────────────────────
info "Verifying build..."
if bun run build 2>&1 | tail -5; then
  ok "Build succeeded"
else
  fail "Build failed — fix errors before deploying"
fi

# ── 9. Commit setup changes ──────────────────────────────────────────
info "Committing setup changes..."
git add -A
if git diff --cached --quiet; then
  ok "No changes to commit"
else
  git commit -m "Setup: standardize for Bun + Railway deployment

- Clean lockfiles (Bun only)
- Add production start script
- Upgrade all dependencies to latest
- Add .railwayignore and update .gitignore
- Add CLAUDE.md

Co-Authored-By: Claude Opus 4.6 <noreply@anthropic.com>"
  ok "Changes committed"
fi

# ── 10. Push ─────────────────────────────────────────────────────────
info "Pushing to origin..."
if git remote get-url origin >/dev/null 2>&1; then
  git push
  ok "Pushed to origin"
else
  warn "No remote origin — skipping push"
fi

# ── 11. Railway setup (optional) ─────────────────────────────────────
echo ""
if command -v railway >/dev/null 2>&1; then
  read -p "$(echo -e "${BLUE}▸${NC}") Set up Railway project? [y/N] " -n 1 -r
  echo ""
  if [[ $REPLY =~ ^[Yy]$ ]]; then
    if railway status >/dev/null 2>&1; then
      ok "Railway project already linked"
    else
      info "Creating Railway project..."
      railway init --name "$PROJECT_NAME"
      ok "Railway project created"
    fi

    info "Deploying..."
    railway up --service "$PROJECT_NAME" 2>&1 || railway up 2>&1
    ok "Deployed"

    info "Generating domain..."
    railway domain 2>&1
    ok "Domain assigned"

    echo ""
    warn "To enable auto-deploy: Railway dashboard → Service Settings → Source → Connect GitHub repo"
  fi
else
  warn "Railway CLI not installed — skipping. Install with: brew install railway"
fi

echo ""
echo -e "${GREEN}━━━ Setup complete! ━━━${NC}"
echo ""
