#!/usr/bin/env python3
"""
Export Claude Code session JSONL transcripts → flat parquet/csv for analysis.

Walks ~/.claude/projects/*/*.jsonl, extracts per-message usage, writes:
  ~/cc-telemetry/messages.csv   (one row per assistant message w/ usage)
  ~/cc-telemetry/sessions.csv   (one row per session: totals, duration, project)

Run anytime. Idempotent — overwrites outputs.

Optional: `cc-session-export --duckdb` opens DuckDB shell with both loaded as views.
"""
import json
import os
import sys
import csv
import glob
import subprocess
from collections import defaultdict
from datetime import datetime


def detect_repo_name():
    """Resolve current cwd → scope name. Git repo → canonical repo (worktree-aware). Else → cwd basename."""
    try:
        common = subprocess.check_output(
            ["git", "rev-parse", "--path-format=absolute", "--git-common-dir"],
            stderr=subprocess.DEVNULL, text=True,
        ).strip()
        name = os.path.basename(os.path.dirname(common))
        if name:
            return name
    except Exception:
        pass
    return os.path.basename(os.getcwd()) or None

ROOT = os.path.expanduser("~/.claude/projects")
OUT = os.path.expanduser("~/cc-telemetry")
os.makedirs(OUT, exist_ok=True)


def parse_ts(s):
    if not s:
        return None
    try:
        return datetime.fromisoformat(s.replace("Z", "+00:00"))
    except Exception:
        return None


def iter_messages():
    project_filter = detect_repo_name()  # default: current repo (worktree-aware)
    for arg in sys.argv[1:]:
        if arg.startswith("--project="):
            project_filter = arg.split("=", 1)[1]
        elif arg == "--all":
            project_filter = None
    if project_filter:
        print(f"scope: {project_filter} (incl. worktrees). use --all for everything.", file=sys.stderr)
    for path in glob.glob(os.path.join(ROOT, "*", "*.jsonl")):
        project_dir = os.path.basename(os.path.dirname(path))
        if project_filter and project_filter not in project_dir:
            continue
        session_id = os.path.splitext(os.path.basename(path))[0]
        try:
            with open(path) as f:
                for line in f:
                    try:
                        d = json.loads(line)
                    except Exception:
                        continue
                    msg = d.get("message")
                    if not isinstance(msg, dict):
                        continue
                    usage = msg.get("usage")
                    if not isinstance(usage, dict):
                        continue
                    yield {
                        "session_id": session_id,
                        "project_dir": project_dir,
                        "cwd": d.get("cwd", ""),
                        "timestamp": d.get("timestamp", ""),
                        "type": d.get("type", ""),
                        "role": msg.get("role", ""),
                        "model": msg.get("model", ""),
                        "input_tokens": usage.get("input_tokens", 0) or 0,
                        "output_tokens": usage.get("output_tokens", 0) or 0,
                        "cache_creation_input_tokens": usage.get("cache_creation_input_tokens", 0) or 0,
                        "cache_read_input_tokens": usage.get("cache_read_input_tokens", 0) or 0,
                        "cache_1h": (usage.get("cache_creation") or {}).get("ephemeral_1h_input_tokens", 0) or 0,
                        "cache_5m": (usage.get("cache_creation") or {}).get("ephemeral_5m_input_tokens", 0) or 0,
                        "service_tier": usage.get("service_tier", ""),
                        "uuid": d.get("uuid", ""),
                    }
        except Exception as e:
            print(f"skip {path}: {e}", file=sys.stderr)


def main():
    msgs = list(iter_messages())
    if not msgs:
        print("no messages found", file=sys.stderr)
        return 1

    msg_path = os.path.join(OUT, "messages.csv")
    with open(msg_path, "w", newline="") as f:
        w = csv.DictWriter(f, fieldnames=list(msgs[0].keys()))
        w.writeheader()
        w.writerows(msgs)

    sessions = defaultdict(lambda: {
        "input_tokens": 0, "output_tokens": 0,
        "cache_creation_input_tokens": 0, "cache_read_input_tokens": 0,
        "cache_1h": 0, "cache_5m": 0,
        "msg_count": 0, "first_ts": None, "last_ts": None,
        "project_dir": "", "cwd": "", "models": set(),
    })
    for m in msgs:
        s = sessions[m["session_id"]]
        for k in ("input_tokens", "output_tokens", "cache_creation_input_tokens",
                  "cache_read_input_tokens", "cache_1h", "cache_5m"):
            s[k] += m[k]
        s["msg_count"] += 1
        ts = parse_ts(m["timestamp"])
        if ts:
            if s["first_ts"] is None or ts < s["first_ts"]:
                s["first_ts"] = ts
            if s["last_ts"] is None or ts > s["last_ts"]:
                s["last_ts"] = ts
        s["project_dir"] = m["project_dir"]
        s["cwd"] = m["cwd"]
        if m["model"]:
            s["models"].add(m["model"])

    sess_path = os.path.join(OUT, "sessions.csv")
    with open(sess_path, "w", newline="") as f:
        w = csv.writer(f)
        w.writerow([
            "session_id", "project_dir", "cwd", "msg_count",
            "first_ts", "last_ts", "duration_min",
            "input_tokens", "output_tokens",
            "cache_creation_input_tokens", "cache_read_input_tokens",
            "cache_1h", "cache_5m", "total_billable_in",
            "cache_hit_ratio", "models",
        ])
        for sid, s in sessions.items():
            dur = ""
            if s["first_ts"] and s["last_ts"]:
                dur = round((s["last_ts"] - s["first_ts"]).total_seconds() / 60, 2)
            total_in = s["input_tokens"] + s["cache_creation_input_tokens"] + s["cache_read_input_tokens"]
            ratio = ""
            if total_in:
                ratio = round(s["cache_read_input_tokens"] / total_in, 4)
            w.writerow([
                sid, s["project_dir"], s["cwd"], s["msg_count"],
                s["first_ts"].isoformat() if s["first_ts"] else "",
                s["last_ts"].isoformat() if s["last_ts"] else "",
                dur,
                s["input_tokens"], s["output_tokens"],
                s["cache_creation_input_tokens"], s["cache_read_input_tokens"],
                s["cache_1h"], s["cache_5m"], total_in, ratio,
                "|".join(sorted(s["models"])),
            ])

    print(f"wrote {len(msgs)} messages → {msg_path}")
    print(f"wrote {len(sessions)} sessions → {sess_path}")

    if "--duckdb" in sys.argv:
        os.execvp("duckdb", ["duckdb", "-c", f"""
            CREATE VIEW messages AS SELECT * FROM read_csv_auto('{msg_path}');
            CREATE VIEW sessions AS SELECT * FROM read_csv_auto('{sess_path}');
            .mode box
            SELECT 'rows loaded' AS info, count(*) AS messages FROM messages;
        """, "-interactive"])

    if "--summary" in sys.argv:
        # quick top-line numbers without duckdb
        total_in = sum(m["cache_creation_input_tokens"] + m["cache_read_input_tokens"] + m["input_tokens"] for m in msgs)
        total_out = sum(m["output_tokens"] for m in msgs)
        cache_read = sum(m["cache_read_input_tokens"] for m in msgs)
        print(f"\nall-time totals: in={total_in:,}  out={total_out:,}  cache_read={cache_read:,}  cache_hit={cache_read/total_in:.1%}")

        from collections import Counter
        by_proj = Counter()
        for m in msgs:
            by_proj[m["project_dir"]] += m["input_tokens"] + m["cache_creation_input_tokens"] + m["cache_read_input_tokens"] + m["output_tokens"]
        print("\ntop projects by total tokens:")
        for proj, tot in by_proj.most_common(10):
            print(f"  {tot:>14,}  {proj}")

    return 0


if __name__ == "__main__":
    sys.exit(main())
