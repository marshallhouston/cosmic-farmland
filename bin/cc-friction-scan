#!/usr/bin/env python3
"""Heuristic friction scanner over CC session JSONL transcripts.

Walks ~/.claude/projects/<scope>/*.jsonl modified within --days window,
applies taxonomy v0 regexes, counts hits per type per session.

Usage:
  cc-friction-scan [--days=N] [--project=NAME] [--all] [--top=N]

Defaults:
  --days=2          last 2 days of session activity
  scope             current git repo (worktree-aware) or cwd basename
  --top=10          show top N sessions by total friction hits

Output: per-friction-type counts + top sessions + sample evidence.
"""
import json
import os
import re
import sys
import glob
import subprocess
from collections import defaultdict, Counter
from datetime import datetime, timedelta, timezone

ROOT = os.path.expanduser("~/.claude/projects")


def detect_repo_name():
    try:
        common = subprocess.check_output(
            ["git", "rev-parse", "--path-format=absolute", "--git-common-dir"],
            stderr=subprocess.DEVNULL, text=True,
        ).strip()
        name = os.path.basename(os.path.dirname(common))
        if name:
            return name
    except Exception:
        pass
    return os.path.basename(os.getcwd()) or None


# --- Friction taxonomy v0 ---
USER_PATTERNS = {
    "copy_clarity": [
        re.compile(r"\bi don'?t (follow|understand|get it)\b", re.I),
        re.compile(r"\bwhat (do|does) (you|that) mean\b", re.I),
        re.compile(r"\bnot clear\b", re.I),
        re.compile(r"\bhuh\?", re.I),
        # NB: dropped /^ahh,/ -- audit 2026-04-27 showed these are user pivots, not confusion.
    ],
    "rule_drift": [
        re.compile(r"\breminder\b.*(don'?t|stop|no)", re.I),
        re.compile(r"\bwe don'?t\b.*(work|do|use)", re.I),
        re.compile(r"\bstop\s+(doing|using)\b", re.I),
    ],
    "stall": [
        re.compile(r"\b(took|taking)\s+(\d+\s+(min|minutes|hours)|so long|too long|forever)\b", re.I),
        re.compile(r"\bno (clear )?progress\b", re.I),
        re.compile(r"\bwhy.*(slow|so long)\b", re.I),
    ],
    "status_begging": [
        re.compile(r"\bstatus\s+\d+\b", re.I),
        re.compile(r"\bstatus\s+of\b", re.I),
        re.compile(r"\bwhat'?s (in|on)\s+\d+\b", re.I),
        re.compile(r"\bwhere are we\b", re.I),
    ],
    "interrupt": [
        re.compile(r"\[Request interrupted by user\]"),
    ],
    "short_yes": [
        # short confirmatory msgs — strong signal model asked needlessly
        re.compile(r"^(yes|y|yep|yeah|ok|okay|do it|go|sure)\.?$", re.I),
    ],
}

ASSISTANT_PATTERNS = {
    "re_asking": [
        re.compile(r"\bwant me to\b", re.I),
        re.compile(r"\bshould i\b", re.I),
        re.compile(r"\bdo you want\b", re.I),
        re.compile(r"\bwould you like\b", re.I),
        re.compile(r"\bshall i\b", re.I),
        re.compile(r"\blet me know if you want\b", re.I),
    ],
}

SAFE_CONTEXT = [
    "delete", "drop table", "force push", "rm -rf", "reset --hard",
    "destructive", "irreversible", "uninstall", "revoke",
]


def parse_args():
    days = 2
    project = detect_repo_name()
    top = 10
    for arg in sys.argv[1:]:
        if arg.startswith("--days="):
            days = int(arg.split("=", 1)[1])
        elif arg.startswith("--project="):
            project = arg.split("=", 1)[1]
        elif arg == "--all":
            project = None
        elif arg.startswith("--top="):
            top = int(arg.split("=", 1)[1])
    return days, project, top


def extract_text(msg):
    content = msg.get("content")
    if isinstance(content, str):
        return content
    if isinstance(content, list):
        out = []
        for c in content:
            if isinstance(c, dict) and c.get("type") == "text":
                out.append(c.get("text", ""))
        return "\n".join(out)
    return ""


def scan_session(path):
    """Return dict: {friction_type: [(line_idx, snippet), ...]}"""
    hits = defaultdict(list)
    try:
        with open(path) as f:
            lines = f.readlines()
    except Exception:
        return hits

    for i, line in enumerate(lines):
        try:
            d = json.loads(line)
        except Exception:
            continue
        t = d.get("type")
        msg = d.get("message", {})
        if not isinstance(msg, dict):
            continue

        if t == "user":
            text = extract_text(msg).strip()
            if not text or "<system-reminder>" in text or "tool_use_id" in text:
                continue
            # skip slash-command invocations + skill-template paste-ins
            if text.startswith("# /") or text.startswith("Base directory for this skill:"):
                continue
            # skip very long msgs (likely template paste)
            if len(text) > 1500:
                continue
            for ftype, pats in USER_PATTERNS.items():
                for pat in pats:
                    m = pat.search(text)
                    if m:
                        hits[ftype].append((i, text[:200].replace("\n", " ")))
                        break

        elif t == "assistant":
            text = extract_text(msg)
            if not text:
                continue
            text_lower = text.lower()
            if any(kw in text_lower for kw in SAFE_CONTEXT):
                continue
            for ftype, pats in ASSISTANT_PATTERNS.items():
                for pat in pats:
                    m = pat.search(text)
                    if m:
                        snippet = text[max(0, m.start() - 40):m.end() + 80].replace("\n", " ")
                        hits[ftype].append((i, snippet))
                        break
    return hits


def main():
    days, project, top = parse_args()
    cutoff = datetime.now(timezone.utc) - timedelta(days=days)

    files = []
    for path in glob.glob(os.path.join(ROOT, "*", "*.jsonl")):
        if project and project not in os.path.basename(os.path.dirname(path)):
            continue
        try:
            mtime = datetime.fromtimestamp(os.path.getmtime(path), timezone.utc)
        except Exception:
            continue
        if mtime < cutoff:
            continue
        files.append(path)

    print(f"scope: {project or 'all'}  window: last {days}d  files: {len(files)}\n")

    totals = Counter()
    per_session = []
    samples = defaultdict(list)

    for path in files:
        hits = scan_session(path)
        n = sum(len(v) for v in hits.values())
        if n == 0:
            continue
        sid = os.path.splitext(os.path.basename(path))[0]
        per_session.append((sid, n, dict(hits)))
        for ftype, h in hits.items():
            totals[ftype] += len(h)
            for _, snippet in h[:2]:
                samples[ftype].append((sid[:8], snippet))

    print("=" * 70)
    print(f"FRICTION TOTALS (window: {days}d, {len(per_session)} sessions w/ hits)")
    print("=" * 70)
    for ftype, n in totals.most_common():
        print(f"  {n:>5}  {ftype}")

    print(f"\n{'=' * 70}\nTOP {top} SESSIONS BY TOTAL HITS\n{'=' * 70}")
    per_session.sort(key=lambda x: -x[1])
    for sid, n, breakdown in per_session[:top]:
        bd = ", ".join(f"{k}={len(v)}" for k, v in sorted(breakdown.items(), key=lambda x: -len(x[1])))
        print(f"  {n:>4}  {sid[:8]}  ({bd})")

    print(f"\n{'=' * 70}\nSAMPLE EVIDENCE (3 per type)\n{'=' * 70}")
    for ftype in totals:
        print(f"\n[{ftype}]")
        for sid, snippet in samples[ftype][:3]:
            print(f"  {sid}: {snippet[:160]}")

    return 0


if __name__ == "__main__":
    sys.exit(main())
